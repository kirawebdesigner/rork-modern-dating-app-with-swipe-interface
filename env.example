# Supabase
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ArifPay Payment Gateway
ARIFPAY_API_KEY=your_arifpay_api_key_here
ARIFPAY_ACCOUNT_NUMBER=your_account_number_here
ARIFPAY_BASE_URL=https://gateway.arifpay.net
ARIFPAY_SESSION_EXPIRY=YYYY-MM-DDTHH:MM:SS

# Webhook Security (REQUIRED for production)
ARIFPAY_WEBHOOK_SECRET=your_webhook_hmac_secret_here

# API URL (optional, auto-detected from request headers)
EXPO_PUBLIC_API_URL=https://api.zewijuna.com
