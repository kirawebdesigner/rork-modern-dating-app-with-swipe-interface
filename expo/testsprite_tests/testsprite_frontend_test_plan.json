  {
    "id": "TC013",
    "title": "Complete profile setup successfully and reach Discovery",
    "description": "Verifies a user can fill required profile details, save, and land on the main discovery screen.",
    "category": "Profile Setup",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/profile\" or \"/onboarding\" or \"/profile-setup\" or \"/\""
      },
      {
        "type": "action",
        "description": "Click on \"Profile Setup\" or \"Complete your profile\" (if shown) to open profile setup"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/profile-setup\""
      },
      {
        "type": "action",
        "description": "Type \"Zewijuna Test User\" into the display name field"
      },
      {
        "type": "action",
        "description": "Type \"Practicing Muslim, family-oriented, and looking for a serious relationship.\" into the bio/description field"
      },
      {
        "type": "action",
        "description": "Select an option in preferences (such as age range, location radius, or intentions) if visible"
      },
      {
        "type": "action",
        "description": "Click the \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/\""
      }
    ]
  },
