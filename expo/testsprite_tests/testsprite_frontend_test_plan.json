  {
    "id": "TC001",
    "title": "Onboarding walkthrough: click through cards then Get Started goes to Signup",
    "description": "Verifies a user can progress through the onboarding walkthrough screens and reach the Signup page via Get Started.",
    "category": "Onboarding",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /onboarding"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Welcome\" is visible"
      },
      {
        "type": "action",
        "description": "Click on \"Next\""
      },
      {
        "type": "assertion",
        "description": "Verify element \"Walkthrough\" is visible"
      },
      {
        "type": "action",
        "description": "Click on \"Next\""
      },
      {
        "type": "action",
        "description": "Click on \"Get Started\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/signup\""
      }
    ]
  },
